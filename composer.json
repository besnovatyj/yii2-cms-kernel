{
  "name": "besnovatyj/yii2-cms-kernel",
  "description": "Тонкое ядро (SDK) модулей Yii2 CMS: базовый класс модуля (CmsModule), базовая миграция (BaseMigration), url-хелпер. Зависит только от yii2 и контрактов.",
  "version": "1.0.0",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Besnovatyj",
      "email": "your-email@example.com"
    }
  ],
  "minimum-stability": "stable",
  "keywords": [
    "yii2",
    "cms",
    "kernel"
  ],
  "config": {
    "sort-packages": true
  },
  "require": {
    "php": ">=8.4",
    "yiisoft/yii2": "~2.0.0",
    "besnovatyj/yii2-cms-contracts": "^1.0"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "Besnovatyj\\Kernel\\": "src/"
    }
  }
}
